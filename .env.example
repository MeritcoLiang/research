# Thought-State Graph Orchestration Engine local environment
# Copy this file to `.env` and fill real secrets locally.
# Never commit `.env`.

# -----------------------------------------------------------------------------
# Runtime defaults
# -----------------------------------------------------------------------------
TSGO_DEFAULT_MESSAGE="请用二级市场分析师视角分析 AAPL 的中期机会和风险。"
TSGO_TRACE_DIR="traces"

# -----------------------------------------------------------------------------
# Azure OpenAI via `az login`
# -----------------------------------------------------------------------------
# Required for Azure OpenAI real calls:
AZURE_OPENAI_ENDPOINT="https://<resource-name>.openai.azure.com"
AZURE_OPENAI_DEPLOYMENT="<deployment-name>"

# Optional Azure OpenAI settings:
AZURE_OPENAI_TEMPERATURE="0.2"
AZURE_OPENAI_MAX_OUTPUT_TOKENS="2048"
AZURE_OPENAI_TIMEOUT="90"
AZURE_OPENAI_TOKEN_SCOPE="https://ai.azure.com/.default"
AZURE_OPENAI_SYSTEM_MESSAGE="你是 Thought-State Graph Orchestration Engine 中的 Operator。必须严格遵守请求的结构化输出约束。"

# -----------------------------------------------------------------------------
# DeepSeek OpenAI-compatible API
# -----------------------------------------------------------------------------
# Required for DeepSeek real calls:
DEEPSEEK_API_KEY="<deepseek-api-key>"

# Optional DeepSeek settings:
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
DEEPSEEK_TEMPERATURE="0.2"
DEEPSEEK_MAX_TOKENS="2048"
DEEPSEEK_TIMEOUT="90"
DEEPSEEK_REASONING_EFFORT="high"
DEEPSEEK_THINKING="enabled"
DEEPSEEK_SYSTEM_MESSAGE="你是 Thought-State Graph Orchestration Engine 中的 Operator。必须严格遵守请求的结构化输出约束。"

# -----------------------------------------------------------------------------
# AIDCProgressExpert (OpenAI Agents SDK + WebSearchTool)
# -----------------------------------------------------------------------------
# Auto selects Azure when AZURE_OPENAI_ENDPOINT is set, otherwise OpenAI.
# Explicit values: openai / azure
AIDC_PROVIDER="azure"

# OpenAI mode only:
OPENAI_API_KEY="<openai-api-key>"

# OpenAI model name or Azure deployment override. If empty in Azure mode,
# AZURE_OPENAI_DEPLOYMENT is used.
AIDC_OPENAI_MODEL="gpt-5.4"
AIDC_SEARCH_CONTEXT_SIZE="high"
AIDC_MAX_TURNS="30"
AIDC_DISABLE_TRACING="true"
AIDC_OUTPUT_DIR="reports/aidc"
